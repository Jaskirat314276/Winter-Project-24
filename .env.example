# Copy to .env (local dev) or paste into /opt/smartschool/.env on EC2.

# --- Domain (used by Caddy, prod only) -----------------------------------
DOMAIN=smartschool.duckdns.org

# --- App image (overridden by GitHub Actions on every deploy) ------------
APP_IMAGE=ghcr.io/jaskirat314276/winter-project-24:latest

# --- Database ------------------------------------------------------------
# Local dev (Homebrew Postgres):
#   DATABASE_URL="postgresql://happydesk:happydesk@localhost:5432/happydesk?schema=public"
# In Docker Compose, the URL is constructed from the three vars below.
POSTGRES_USER=smartschool
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=smartschool

# --- Clerk ---------------------------------------------------------------
# DEV keys (pk_test_ / sk_test_) — only valid on localhost / *.clerk.dev
# PROD keys (pk_live_ / sk_live_) — required for any real domain
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Cloudinary ----------------------------------------------------------
# Cloud name from your Cloudinary dashboard. The unsigned upload preset must
# be named "school" (it's hard-coded in TeacherForm/StudentForm).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
